// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A URL agora é lida do prisma.config.ts automaticamente
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  pokemons Pokemon[]
}

model Pokemon {
  id            Int    @id @default(autoincrement())
  name          String
  type          String
  level         Int
  hp            Int
  pokedexNumber Int
  ownerId       Int
  owner         User   @relation(fields: [ownerId], references: [id])
}