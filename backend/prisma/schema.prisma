generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  pokemons Pokemon[]
}

model Pokemon {
  id            Int    @id @default(autoincrement())
  name          String
  type          String
  level         Int
  hp            Int
  pokedexNumber Int
  ownerId       Int
  owner         User   @relation(fields: [ownerId], references: [id])
}

